# SAP Broker MCP Server Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Broker Transport
# =============================================================================

# Transport mode: "stdio" (dev, no auth) or "http" (production, auth required)
BROKER_TRANSPORT=stdio

# HTTP bind address and port (only used when BROKER_TRANSPORT=http)
BROKER_HOST=127.0.0.1
BROKER_PORT=3000

# Enable HTTPS for the broker endpoint. When true, BROKER_PORT serves TLS.
# BROKER_TLS=true
# BROKER_TLS_KEY=/opt/sap-broker/tls/key.pem
# BROKER_TLS_CERT=/opt/sap-broker/tls/cert.pem

# Path to broker config YAML (default: broker.config.yaml in working directory)
# Only required for HTTP mode — defines profiles, scopes, and tokens.
# BROKER_CONFIG=./broker.config.yaml

# =============================================================================
# Required - HANA Connection
# =============================================================================

HANA_HOST=your-hana-host.example.com
HANA_PORT=30015
HANA_USER=your_username
HANA_PASSWORD=your_password

# =============================================================================
# Optional - SAP Service Layer (required for write tools)
# =============================================================================

# If SAP_BASE_URL is not set, write tools are unavailable (read-only mode).
# SAP_BASE_URL=https://sap.example.com:50000
# SAP_COMPANY_DB=YOUR_COMPANY_DB
# SAP_USERNAME=your_sap_user
# SAP_PASSWORD=your_sap_password

# =============================================================================
# Optional - Schema Restriction
# =============================================================================

# Restrict access to a single schema (leave empty for all accessible schemas)
HANA_SCHEMA=

# =============================================================================
# Optional - Security Settings
# =============================================================================

HANA_ENCRYPT=true
HANA_SSL_VALIDATE_CERTIFICATE=true

# =============================================================================
# Optional - Safety Limits
# =============================================================================

HANA_ROW_LIMIT=1000
HANA_QUERY_TIMEOUT=30000
HANA_CONNECTION_TIMEOUT=5000
