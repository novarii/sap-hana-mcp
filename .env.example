# SAP HANA MCP Server Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Required - Connection Settings
# =============================================================================

# HANA server hostname or IP address
HANA_HOST=your-hana-host.example.com

# HANA port (default: 30015 for single-container, 3<instance>15 for tenant)
HANA_PORT=30015

# Database user credentials
HANA_USER=your_username
HANA_PASSWORD=your_password

# =============================================================================
# Optional - Schema Restriction
# =============================================================================

# Restrict access to a single schema (leave empty for all accessible schemas)
# When set, only this schema will be visible/queryable
HANA_SCHEMA=

# =============================================================================
# Optional - Security Settings
# =============================================================================

# Enable TLS encryption (default: true, recommended for production)
HANA_ENCRYPT=true

# Validate SSL certificate (default: true, set false for self-signed certs)
HANA_SSL_VALIDATE_CERTIFICATE=true

# =============================================================================
# Optional - Safety Limits
# =============================================================================

# Maximum rows returned per query (default: 1000)
HANA_ROW_LIMIT=1000

# Maximum result size in bytes (default: 5242880 = 5MB)
HANA_MAX_RESULT_SIZE=5242880

# Query timeout in milliseconds (default: 30000 = 30 seconds)
HANA_QUERY_TIMEOUT=30000

# Connection timeout in milliseconds (default: 5000 = 5 seconds)
HANA_CONNECTION_TIMEOUT=5000
